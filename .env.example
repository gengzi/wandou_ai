# Frontend -> Spring Boot backend API base URL.
VITE_API_BASE_URL="http://localhost:8080"

# Node/Express Gemini proxy API key.
# Required only if you use the legacy /api/chat endpoint in server.ts.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Spring Boot backend settings.
# mock = deterministic local responses; replace when a real provider is implemented.
WANDOU_AI_PROVIDER_TYPE="mock"

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
