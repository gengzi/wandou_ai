# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# BACKEND_URL: Server-side Spring Boot API address used by the Web/Node proxy.
BACKEND_URL="http://localhost:8080"

# VITE_API_BASE_URL: Optional browser-facing API override.
# Leave empty to use same-origin /api and let Vite/Node proxy to BACKEND_URL.
VITE_API_BASE_URL=""

# Docker Compose port mappings. WEB_PORT defaults to 3001 to avoid common
# local conflicts with Grafana on 3000.
WEB_PORT=3001
BACKEND_PORT=8080

# Video generation and object storage. The default video provider is a mock
# adapter; MinIO is used as a local S3-compatible object store.
WANDOU_AI_VIDEO_PROVIDER="mock"
WANDOU_AI_STORAGE_TYPE="minio"
MINIO_IMAGE="minio/minio:RELEASE.2025-04-22T22-12-26Z"
MINIO_ROOT_USER="wandouminio"
MINIO_ROOT_PASSWORD="wandouminio123"
MINIO_BUCKET="wandou-assets"
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
WANDOU_AI_MINIO_PUBLIC_BASE_URL="http://localhost:9000"

# Optional Docker base image overrides for slow or blocked Docker Hub networks.
NODE_IMAGE="node:22-alpine"
MAVEN_IMAGE="maven:3.9.9-eclipse-temurin-17"
JRE_IMAGE="eclipse-temurin:17-jre"
